---
type Props = {
  href: string;
  label: string;
  external?: boolean;
  download?: boolean;
};

const { href, label, external = false, download = false } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center rounded border border-border bg-bg/70 px-3 py-1.5 font-mono text-xs text-text transition duration-200 hover:border-accent hover:text-accent hover:shadow-[0_0_20px_rgba(138,245,162,0.18)]"
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
  download={download ? true : undefined}
>
  [{label}]
</a>
